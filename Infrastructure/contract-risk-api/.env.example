# Copy to .env and edit
HOST=0.0.0.0
PORT=8080
DEBUG=false

# Add your Next.js URL here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Path to your trained model weights
# If the directory doesn't exist, LR fallback is used automatically
MODEL_DIR=models/roberta-finetuned

CONFIDENCE_THRESHOLD=0.10
TRIAGE_URGENT_THRESHOLD=65
TRIAGE_FLAG_THRESHOLD=30
